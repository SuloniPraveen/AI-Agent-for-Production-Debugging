# Template only — copy to .env.development and fill in real values.
#   cp .env.example .env.development
# This repo commits .env.example with EMPTY secrets on purpose (safe to share).
# Your real OPENAI_API_KEY and JWT_SECRET_KEY live in .env.development (gitignored).

APP_ENV=development

# Required: non-empty values in .env.development (empty OPENAI_API_KEY= will break Docker app startup).
OPENAI_API_KEY=
JWT_SECRET_KEY=

# Phase 4 demo: shared secret for Streamlit + API (no JWT). Compose default: demo-local-review-only
DEMO_API_KEY=demo-local-review-only
# Streamlit -> API chat read timeout (seconds). Compose demo default 1800.
# DEMO_CHAT_TIMEOUT=1800

# Mem0: default false in code; set true to enable. Retrieve uses OpenAI + pgvector each chat.
# LONG_TERM_MEMORY_ENABLED=false
# LONG_TERM_MEMORY_RETRIEVE_TIMEOUT_SECONDS=12
# Agent graph node steps (chat <-> tool_call). Default 16 — raise only if you need many tool rounds.
# LANGGRAPH_RECURSION_LIMIT=16
# Log chunking: split when a window hits this many lines OR LOG_CHUNK_MAX_CHARS (default 8000). Default 24 lines/chunk.
# LOG_LINES_PER_CHUNK=24
# Input trim for prepare_messages (keep tool results in context). Default 28000.
# CHAT_HISTORY_TRIM_MAX_TOKENS=28000
# LLM max *output* tokens (separate from trim above).
# MAX_TOKENS=2000

POSTGRES_HOST=localhost
# Use 5433 when the DB runs in Docker and you also have Postgres on the Mac (brew) using 5432.
POSTGRES_PORT=5433
POSTGRES_DB=food_order_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional: log search cache (Phase 2). Compose sets redis://redis:6379/0 for the app container.
# Local uv run: start Redis (e.g. docker run -p 6379:6379 redis:7-alpine) then:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=
LOG_SEARCH_CACHE_TTL_SECONDS=600

# Log vector search: default top-3 chunks per search; max 5. Scoped to user uploads (latest batch unless focus_log_batch_id).
# LOG_SEARCH_DEFAULT_TOP_K=3
# LOG_SEARCH_MAX_TOP_K=5

# Log ingest: stay under OpenAI embedding max input (~300k tokens/request)
# LOG_INGEST_EMBED_BATCH=32
# LOG_INGEST_EMBED_MAX_CHARS=400000
# Pause between embed batches to avoid TPM 429 (default 1.5s). Set 0 to disable.
# LOG_INGEST_EMBED_PAUSE_SECONDS=1.5
